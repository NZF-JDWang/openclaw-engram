{
  "id": "engram",
  "kind": "context-engine",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "dbPath": {
        "type": "string"
      },
      "personaPath": {
        "type": "string"
      },
      "exportPath": {
        "type": "string"
      },
      "summarizationProvider": {
        "type": "string"
      },
      "summarizationModel": {
        "type": "string"
      },
      "kbEnabled": {
        "type": "boolean"
      },
      "kbCollections": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "path", "pattern"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "pattern": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "indexMode": {
              "type": "string",
              "enum": ["full", "pointer"]
            },
            "recallWeight": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      },
      "openclawMemoryCompat": {
        "type": "boolean"
      },
      "openclawMemoryWorkspacePath": {
        "type": "string"
      },
      "openclawCanonicalMemory": {
        "type": "boolean"
      },
      "kbAutoIndexSessions": {
        "type": "boolean"
      },
      "kbSessionIndexCircuitBreaker": {
        "type": "boolean"
      },
      "kbAutoIndexOnStart": {
        "type": "boolean"
      },
      "recallEnabled": {
        "type": "boolean"
      },
      "embedEnabled": {
        "type": "boolean"
      },
      "embedApiUrl": {
        "type": "string"
      },
      "embedApiModel": {
        "type": "string"
      },
      "embedApiKey": {
        "type": "string"
      },
      "embedBatchSize": {
        "type": "integer",
        "minimum": 1
      },
      "contextThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "freshTailCount": {
        "type": "integer",
        "minimum": 1
      },
      "leafChunkTokens": {
        "type": "integer",
        "minimum": 1000
      },
      "leafTargetTokens": {
        "type": "integer",
        "minimum": 100
      },
      "condensedTargetTokens": {
        "type": "integer",
        "minimum": 100
      },
      "incrementalMaxDepth": {
        "type": "integer",
        "minimum": -1
      },
      "compactionMaxDepth": {
        "type": "integer",
        "minimum": -1
      },
      "newSessionRetainDepth": {
        "type": "integer",
        "minimum": -1
      },
      "maxMessageContentBytes": {
        "type": "integer",
        "minimum": 256
      },
      "pruneSummarizedMessages": {
        "type": "boolean"
      },
      "pruneMinAgeDays": {
        "type": "integer",
        "minimum": 0
      },
      "dbSizeWarningMb": {
        "type": "integer",
        "minimum": 1
      },
      "summaryQualityThreshold": {
        "type": "integer",
        "minimum": 1
      },
      "kbSearchTimeoutMs": {
        "type": "integer",
        "minimum": 1
      },
      "maxSearchCandidates": {
        "type": "integer",
        "minimum": 1
      },
      "recallMaxTokens": {
        "type": "integer",
        "minimum": 1
      },
      "recallMaxSnippetChars": {
        "type": "integer",
        "minimum": 40
      },
      "recallMaxResults": {
        "type": "integer",
        "minimum": 1
      },
      "recallPrependMaxTokens": {
        "type": "integer",
        "minimum": 1
      },
      "activeRecallEnabled": {
        "type": "boolean"
      },
      "activeRecallMinQueryChars": {
        "type": "integer",
        "minimum": 1
      },
      "activeRecallMaxSummaryChars": {
        "type": "integer",
        "minimum": 40
      },
      "recallShadowMode": {
        "type": "boolean"
      },
      "recallShadowLogFile": {
        "type": "string"
      },
      "recallKeywordBypassMinLength": {
        "type": "integer",
        "minimum": 1
      },
      "recallKeywordBypassMaxTerms": {
        "type": "integer",
        "minimum": 1
      },
      "recallRrfK": {
        "type": "integer",
        "minimum": 1
      },
      "recallMinScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "recallGapThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "recallHighConfidenceScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "recallSessionMaxResults": {
        "type": "integer",
        "minimum": 0
      },
      "recallSessionMinScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "recallFeedbackEnabled": {
        "type": "boolean"
      },
      "kbIncrementalSync": {
        "type": "boolean"
      },
      "autoDetectVaults": {
        "type": "boolean"
      },
      "personaFile": {
        "type": "string"
      },
      "summaryProvider": {
        "type": "string"
      },
      "summaryModel": {
        "type": "string"
      },
      "collections": {
        "type": "array",
        "items": {
          "type": "object"
        }
      },
      "autoIndexOnStart": {
        "type": "boolean"
      },
      "indexSessions": {
        "type": "boolean"
      },
      "sessionIndexCircuitBreaker": {
        "type": "boolean"
      },
      "searchTimeoutMs": {
        "type": "integer",
        "minimum": 1
      },
      "searchCandidates": {
        "type": "integer",
        "minimum": 1
      },
      "embeddingEnabled": {
        "type": "boolean"
      },
      "embeddingApiUrl": {
        "type": "string"
      },
      "embeddingModel": {
        "type": "string"
      },
      "embeddingApiKey": {
        "type": "string"
      },
      "embeddingBatchSize": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "uiHints": {
    "enabled": {
      "label": "Enabled",
      "help": "Enable or disable Engram without uninstalling it"
    },
    "dbPath": {
      "label": "Database Path",
      "help": "Path to the Engram SQLite database (default: <OPENCLAW_STATE_DIR>/engram.db; falls back to ~/.openclaw/engram.db)"
    },
    "recallEnabled": {
      "label": "Recall Enabled",
      "help": "Enable proactive memory injection before prompt build"
    },
    "kbEnabled": {
      "label": "Knowledge Base Enabled",
      "help": "Enable indexing and retrieval for markdown collections"
    },
    "maxMessageContentBytes": {
      "label": "Max Message Bytes",
      "help": "Cap stored message and tool content size to limit database growth"
    },
    "pruneSummarizedMessages": {
      "label": "Prune Summarized Messages",
      "help": "Delete older raw messages once they have been safely condensed into higher-level summaries"
    },
    "pruneMinAgeDays": {
      "label": "Prune Min Age Days",
      "help": "Only prune conversations whose raw messages are at least this many days old"
    },
    "compactionMaxDepth": {
      "label": "Compaction Max Depth",
      "help": "Maximum summary depth to build during compaction passes"
    },
    "summaryQualityThreshold": {
      "label": "Summary Quality Threshold",
      "help": "Minimum quality score required before a summary is eligible for higher-level compaction"
    },
    "dbSizeWarningMb": {
      "label": "DB Size Warning MB",
      "help": "Warn in status output when the Engram database exceeds this size"
    },
    "embedEnabled": {
      "label": "Embeddings Enabled",
      "help": "Enable optional embedding-based reranking via an OpenAI-compatible endpoint"
    },
    "recallSessionMaxResults": {
      "label": "Session Recall Max Results",
      "help": "Maximum number of session-derived recall results per turn"
    },
    "recallSessionMinScore": {
      "label": "Session Recall Min Score",
      "help": "Minimum relevance score for session recall injection"
    },
    "recallFeedbackEnabled": {
      "label": "Recall Feedback Enabled",
      "help": "Track which recalled memories are actually used"
    },
    "kbIncrementalSync": {
      "label": "Incremental KB Sync",
      "help": "Only re-index files that changed since last sync"
    },
    "autoDetectVaults": {
      "label": "Auto-Detect Vaults",
      "help": "Automatically discover and index Obsidian vaults on startup"
    }
  }
}
